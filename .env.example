NEON_DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@ep-royal-base-a1qjyz9s.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
SUPABASE_DATABASE_URL=postgresql://postgres.qmaphtslnvvifkzmbrvh:YOUR_PASSWORD@aws-1-ap-south-1.pooler.supabase.com:5432/postgres
DASHBOARD_PASSWORD=changeme

# ── Microsoft (Entra ID) login via oauth2-proxy ───────────────────────────
# Fill these from the Azure app registration (see SETUP_AUTH_TRAEFIK.md).
OAUTH2_PROXY_PROVIDER=oidc
OAUTH2_PROXY_OIDC_ISSUER_URL=https://login.microsoftonline.com/YOUR_TENANT_ID/v2.0
OAUTH2_PROXY_CLIENT_ID=YOUR_AZURE_APP_CLIENT_ID
OAUTH2_PROXY_CLIENT_SECRET=YOUR_AZURE_CLIENT_SECRET_VALUE
# Generate once on the VPS:  openssl rand -base64 32
OAUTH2_PROXY_COOKIE_SECRET=GENERATE_A_RANDOM_32_BYTE_SECRET
# Only these email domains may log in (comma-separated to add more):
OAUTH2_PROXY_EMAIL_DOMAINS=karboncard.com
OAUTH2_PROXY_REDIRECT_URL=https://ops.aiaccountant.com/oauth2/callback
OAUTH2_PROXY_COOKIE_SECURE=true
OAUTH2_PROXY_WHITELIST_DOMAINS=ops.aiaccountant.com
# If login fails with an "email domain" error, Azure didn't return an email
# claim — uncomment the next line to use the user's UPN instead:
# OAUTH2_PROXY_OIDC_EMAIL_CLAIM=preferred_username
